# Groq API — get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/focus_guardian

# JWT Secret — use a long random string
JWT_SECRET=your_very_long_random_secret_key_here

# Gmail credentials for email verification
# Use Gmail App Password (not your regular password)
# Get it: Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your_gmail@gmail.com

# Google OAuth Client ID
# Get it: console.cloud.google.com → APIs & Services → Credentials → OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

#resend API key for email sending
RESEND_API_KEY = your_resend_api_key_here
